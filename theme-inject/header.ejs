<%
const vm = page_view_model(page)
const showSearch = theme.search.enable && page.disable_search !== true
const showDarkMode = theme.dark_mode && theme.dark_mode.enable
var banner_img_height = parseFloat(page.banner_img_height || theme.index.banner_img_height)
function activeClass(section) {
  return vm.currentSection === section ? ' active' : ''
}
%>

<div class="header-inner" style="height: <%= banner_img_height %>vh;">
  <nav id="navbar" class="navbar fixed-top navbar-expand-lg navbar-dark scrolling-navbar">
    <div class="container">
      <a class="navbar-brand" href="<%= vm.homePath %>">
        <strong><%= theme.navbar.blog_title || config.title %></strong>
      </a>

      <button id="navbar-toggler-btn" class="navbar-toggler" type="button" data-toggle="collapse"
              data-target="#navbarSupportedContent"
              aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <div class="animated-icon"><span></span><span></span><span></span></div>
      </button>

      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav ml-auto text-center">
          <li class="nav-item<%= activeClass('home') %>">
            <a class="nav-link" href="<%= vm.homePath %>">
              <i class="iconfont icon-home-fill"></i>
              <span><%= __('home.menu') %></span>
            </a>
          </li>
          <li class="nav-item<%= activeClass('archive') %>">
            <a class="nav-link" href="<%= vm.archivePath %>">
              <i class="iconfont icon-archive-fill"></i>
              <span><%= __('archive.menu') %></span>
            </a>
          </li>
          <li class="nav-item<%= activeClass('about') %>">
            <a class="nav-link" href="<%= vm.aboutPath %>">
              <i class="iconfont icon-user-fill"></i>
              <span><%= __('about.menu') %></span>
            </a>
          </li>
          <li class="nav-item dropdown locale-switch">
            <a class="nav-link dropdown-toggle" target="_self" href="javascript:;" role="button"
               data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <span class="locale-switch__current"><%= vm.currentLocale.display_name %></span>
            </a>
            <div class="dropdown-menu dropdown-menu-right">
              <% vm.languageOptions.forEach(function(option) { %>
                <a class="dropdown-item<%= option.isCurrent ? ' active' : '' %>" href="<%= option.relativeUrl %>" data-locale-preference="<%= option.lang_path %>">
                  <span><%= option.display_name %></span>
                </a>
              <% }) %>
            </div>
          </li>
          <% if (showSearch) { %>
            <li class="nav-item" id="search-btn">
              <a class="nav-link" target="_self" href="javascript:;" data-toggle="modal" data-target="#modalSearch" aria-label="Search">
                <i class="iconfont icon-search"></i>
              </a>
            </li>
            <% import_js(theme.static_prefix.internal_js, 'local-search.js') %>
          <% } %>
          <% if (showDarkMode) { %>
            <li class="nav-item" id="color-toggle-btn">
              <a class="nav-link" target="_self" href="javascript:;" aria-label="Color Toggle">
                <i class="iconfont icon-dark" id="color-toggle-icon"></i>
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div id="mobile-grid-menu" class="d-lg-none">
    <div class="mobile-grid-menu-inner">
      <div class="container">
        <div class="row">
          <div class="col-4 mobile-grid-cell">
            <a href="<%= vm.homePath %>">
              <div class="mobile-grid-item">
                <i class="iconfont icon-home-fill"></i>
                <span><%= __('home.menu') %></span>
              </div>
            </a>
          </div>
          <div class="col-4 mobile-grid-cell">
            <a href="<%= vm.archivePath %>">
              <div class="mobile-grid-item">
                <i class="iconfont icon-archive-fill"></i>
                <span><%= __('archive.menu') %></span>
              </div>
            </a>
          </div>
          <div class="col-4 mobile-grid-cell">
            <a href="<%= vm.aboutPath %>">
              <div class="mobile-grid-item">
                <i class="iconfont icon-user-fill"></i>
                <span><%= __('about.menu') %></span>
              </div>
            </a>
          </div>

          <div class="col-12 mobile-grid-group-header">
            <span><%= vm.currentLocale.display_name %></span>
          </div>
          <% vm.languageOptions.forEach(function(option) { %>
            <div class="col-4 mobile-grid-cell">
              <a href="<%= option.relativeUrl %>" data-locale-preference="<%= option.lang_path %>">
                <div class="mobile-grid-item<%= option.isCurrent ? ' mobile-grid-item--active' : '' %>">
                  <i class="iconfont icon-link-fill"></i>
                  <span><%= option.display_name %></span>
                </div>
              </a>
            </div>
          <% }) %>

          <% if (showSearch) { %>
            <div class="col-4 mobile-grid-cell" id="mobile-search-btn">
              <a href="javascript:;" data-toggle="modal" data-target="#modalSearch" aria-label="Search">
                <div class="mobile-grid-item">
                  <i class="iconfont icon-search"></i>
                  <span><%= __('search.title') %></span>
                </div>
              </a>
            </div>
          <% } %>
          <% if (showDarkMode) { %>
            <div class="col-4 mobile-grid-cell" id="mobile-color-toggle-btn"
                 data-label-light="<%= __('darkmode.light') %>"
                 data-label-dark="<%= __('darkmode.dark') %>">
              <a href="javascript:;" aria-label="Color Toggle">
                <div class="mobile-grid-item">
                  <i class="iconfont icon-dark" id="mobile-color-toggle-icon"></i>
                  <span id="mobile-color-toggle-label"><%= __('darkmode.dark') %></span>
                </div>
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <%- partial('_partials/header/banner') %>
</div>
